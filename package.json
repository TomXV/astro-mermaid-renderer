{
  "name": "astro-mermaid-renderer",
  "version": "0.1.2",
  "description": "Astro で Mermaid 図を描画するコンポーネント集。SVGレンダリング・ズーム/パン対応プレビューモーダル・Markdownコードブロック変換を提供します。",
  "keywords": [
    "astro",
    "mermaid",
    "diagram",
    "svg",
    "component"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/TomXV/astro-mermaid-renderer.git"
  },
  "type": "module",
  "exports": {
    "./Mermaid.astro": "./src/components/Mermaid.astro",
    "./MermaidLoader.astro": "./src/components/MermaidLoader.astro",
    "./remark-mermaid": {
      "types": "./src/plugins/remark-mermaid.d.ts",
      "default": "./src/plugins/remark-mermaid.mjs"
    }
  },
  "files": [
    "src/components",
    "src/plugins"
  ],
  "scripts": {
    "dev": "bun run index.ts dev",
    "debug": "bun run index.ts debug",
    "build": "bun run index.ts build",
    "preview": "bun run index.ts preview",
    "check": "bun run index.ts check",
    "format:check": "bun run index.ts format:check"
  },
  "peerDependencies": {
    "astro": ">=4.0.0",
    "typescript": "^5"
  },
  "dependencies": {
    "unist-util-visit": "^5.1.0"
  },
  "devDependencies": {
    "@astrojs/mdx": "^5.0.0",
    "@types/bun": "latest",
    "astro": "6.1.1",
    "prettier": "^3.6.2",
    "prettier-plugin-astro": "^0.14.1"
  }
}
